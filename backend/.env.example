# Banco de dados PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/planeja_obra

# JWT (gere um segredo forte em produção)
JWT_SECRET=seu_segredo_jwt_aqui_mude_em_producao

# Porta do servidor
PORT=3001

# URL do frontend (para CORS)
FRONTEND_URL=http://localhost:3000

# Pasta de uploads (relativa ao backend)
UPLOAD_DIR=uploads
